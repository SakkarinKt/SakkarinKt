---
import type { Project } from '../data/projects';

interface Props {
	project: Project;
}

const { project } = Astro.props;
const hasLink = project.link && !project.link.href.startsWith('TODO');
---

<article class="card">
	<p class="card__period mono-label">
		{project.period}
		{project.status === 'in-progress' && <span class="card__status">in progress</span>}
	</p>
	<h3>{project.title}</h3>
	<p>{project.description}</p>
	<ul class="tag-list">
		{project.tags.map((tag) => <li>{tag}</li>)}
	</ul>
	{hasLink && (
		<a
			class="card__link"
			href={project.link!.href}
			target={project.link!.href.startsWith('http') ? '_blank' : undefined}
			rel={project.link!.href.startsWith('http') ? 'noopener noreferrer' : undefined}
		>
			{project.link!.label} →
		</a>
	)}
	{project.note && <p class="card__note">{project.note}</p>}
</article>

<style>
	.card {
		border: 1px solid var(--border);
		border-radius: 1rem;
		padding: 1.75rem;
		display: grid;
		gap: 1rem;
		align-content: start;
		background: var(--surface);
	}

	.card h3 {
		font-size: 1.15em;
		margin: 0;
	}

	.card p {
		margin: 0;
		font-size: 0.95rem;
	}

	.card__period {
		display: flex;
		align-items: center;
		gap: 0.6em;
		margin: 0;
	}

	.card__status {
		font-family: var(--mono);
		font-size: 0.7rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--accent);
		border: 1px solid var(--accent);
		border-radius: 999px;
		padding: 0.1em 0.7em;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.tag-list li {
		font-family: var(--mono);
		font-size: 0.72rem;
		letter-spacing: 0.03em;
		color: var(--text-muted);
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 0.15em 0.75em;
	}

	.card__link {
		font-weight: 600;
		color: var(--accent);
		text-decoration: none;
	}

	.card__link:hover {
		color: var(--accent-hover);
	}

	.card__note {
		font-size: 0.85rem;
		color: var(--text-muted);
	}
</style>

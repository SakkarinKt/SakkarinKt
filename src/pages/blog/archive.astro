---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE, BASE } from '../../consts';

const posts = (await getCollection('blog', ({ data }) => data.archived)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} · Archive`} description="Older posts kept for the record." />
	</head>
	<body>
		<Header />
		<main>
			<section>
				<header class="archive-header">
					<h1>Archive</h1>
					<p>Older posts kept for the record.</p>
				</header>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`${BASE}blog/${post.id}/`}>
									<span class="title">{post.data.title}</span>
									<span class="date mono-label">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							</li>
						))
					}
				</ul>
				<a class="back-link" href={`${BASE}blog/`}>← Back to blog</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.archive-header {
		margin-bottom: 2.5rem;
	}

	.archive-header p {
		color: var(--text-muted);
		margin: 0;
	}

	ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1rem;
	}

	ul li a {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.5rem 1.5rem;
		padding: 0.75rem 0;
		border-bottom: 1px solid var(--border);
		text-decoration: none;
	}

	.title {
		color: var(--text-strong);
		font-weight: 700;
	}

	ul li a:hover .title {
		color: var(--accent);
	}

	.back-link {
		display: inline-block;
		margin-top: 3rem;
		font-family: var(--mono);
		font-size: 0.85rem;
		letter-spacing: 0.04em;
		color: var(--text-muted);
		text-decoration: none;
	}

	.back-link:hover {
		color: var(--accent);
	}
</style>

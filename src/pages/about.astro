---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { skills } from '../data/skills';

const hero = {
	title: 'About Me',
	role: 'AI/ML Engineer · RL & LLM Systems',
	intro:
		'Reinforcement-learning–driven engineer turning research into maintainable, observable products.',
	availability: 'Open to senior AI Engineer and Data Scientist roles.',
};


const experience = [
	{
		period: '2023 — Present',
		title: 'Software Developer · SystemWeb Technologies',
		points: [
			'Built a Portfolio Management System and currently developing a Transfer Agent System for asset & wealth management clients, in C# and JavaScript.',
			'Collaborate with cross-functional teams of 5–10 developers across Thailand and Taiwan to deliver scalable financial applications.',
		],
	},
	{
		period: '2020',
		title: 'Data Analyst · Tri Petch IT Solutions',
		points: [
			'Designed a machine-learning predictive model for Isuzu Motors marketing campaigns.',
			'Managed the supporting databases and cloud services end to end.',
		],
	},
];

const education = [
	{
		period: '2024',
		title: 'National Tsing Hua University · Taiwan',
		points: [
			'MSc. in Institute of Information Systems and Applications',
			'Master Thesis: Enhancing Autonomous Driving Using Double Critic and MCTS for Inverse Reinforcement Learning',
		],
	},
	{
		period: '2017',
		title: 'Mahidol University · Thailand',
		points: [
			'BSc. in Actuarial Sciences',
			'Mathematics, statistics, and financial modeling — the applied-math foundation under my ML work.',
		],
	},
];

const values = [
	{
		label: 'Integrity first',
		description:
			'I flag risks, costs, and “this won’t work” the moment I see them — plans should be accurate, not comfortable.',
	},
	{
		label: 'Production is the bar',
		description:
			'A result counts when it survives code review, tests, and real traffic — I build for the deploy, not the demo.',
	},
	{
		label: 'Impact over output',
		description:
			'Start from the user’s problem, attach a metric, and let the data say whether it worked.',
	},
];

const beyondWork = [
	{
		title: 'Learning',
		description: 'Currently deep in GPU inference optimization (TensorRT-LLM, Triton) and agentic workflow design.',
	},
	{
		title: 'Outside the Screen',
		description: 'Catch me practicing BJJ, testing new recipes, or watching new films.',
	},
];
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} · About`} description={`About ${SITE_TITLE} — AI/ML engineer working across reinforcement learning, LLM systems, and production financial software.`} />
	</head>
	<body>
		<Header />
		<main>
			<section class="section hero">
				<div class="hero__header">
					<p class="eyebrow mono-label">{hero.role}</p>
					<h1>{hero.title}</h1>
					<p class="intro">{hero.intro}</p>
					<p class="availability">{hero.availability}</p>
				</div>
			</section>

			<section class="section">
				<header class="section__header">
					<h2>Experience Snapshot</h2>
				</header>
				<div class="timeline">
					{experience.map((role) => (
						<article class="timeline__item">
							<header>
								<p class="timeline__period mono-label">{role.period}</p>
								<h3>{role.title}</h3>
							</header>
							<ul>
								{role.points.map((point) => (
									<li>{point}</li>
								))}
							</ul>
						</article>
					))}
				</div>
			</section>

			<section class="section">
				<header class="section__header">
					<h2>Education</h2>
				</header>
				<div class="timeline">
					{education.map((role) => (
						<article class="timeline__item">
							<header>
								<p class="timeline__period mono-label">{role.period}</p>
								<h3>{role.title}</h3>
							</header>
							<ul>
								{role.points.map((point) => (
									<li>{point}</li>
								))}
							</ul>
						</article>
					))}
				</div>
			</section>

			<section class="section section--muted">
				<header class="section__header">
					<h2>Values I Work By</h2>
				</header>
				<ul class="values">
					{values.map((value) => (
						<li>
							<h3>{value.label}</h3>
							<p>{value.description}</p>
						</li>
					))}
				</ul>
			</section>

			<section class="section">
				<header class="section__header">
					<h2>Skills &amp; Tools</h2>
				</header>
				<div class="skill-rows">
					{skills.map((group) => (
						<div class="skill-row">
							<h3 class="mono-label">{group.category}</h3>
							<ul class="chip-list">
								{group.items.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</div>
					))}
				</div>
			</section>

			<section class="section">
				<header class="section__header">
					<h2>Beyond the Keyboard</h2>
				</header>
				<div class="cards">
					{beyondWork.map((item) => (
						<article class="card">
							<h3>{item.title}</h3>
							<p>{item.description}</p>
						</article>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: auto;
		max-width: 900px;
		margin: 0 auto;
		padding: 4rem 1.5rem 6rem;
		display: flex;
		flex-direction: column;
		gap: 4rem;
	}

	.section {
		display: grid;
		gap: 2rem;
	}

	.section--muted {
		background: var(--surface);
		padding: 3rem 2rem;
		border-radius: 1rem;
		border: 1px solid var(--border);
	}

	.section__header {
		display: grid;
		gap: 0.75rem;
	}

	.hero {
		gap: 1.5rem;
	}

	.hero__header {
		display: grid;
		gap: 1rem;
	}

	.intro {
		max-width: 60ch;
		font-size: 1.1rem;
		color: var(--text);
	}

	.availability {
		font-weight: 600;
		color: var(--accent);
	}

	.timeline {
		display: grid;
		gap: 2rem;
	}

	.timeline__item {
		border-left: 3px solid var(--accent);
		padding-left: 1.5rem;
		display: grid;
		gap: 1rem;
	}

	.timeline ul {
		margin: 0;
		padding-left: 1.2rem;
		display: grid;
		gap: 0.6rem;
	}

	.values {
		display: grid;
		gap: 1.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.values li {
		display: grid;
		gap: 0.5rem;
	}

	.values h3 {
		font-size: 1.15em;
	}

	.values p {
		margin: 0;
		color: var(--text);
	}

	.skill-rows {
		display: grid;
		gap: 1.75rem;
	}

	.skill-row {
		display: grid;
		gap: 0.75rem;
	}

	.skill-row h3 {
		margin: 0;
		font-weight: 400;
	}

	.chip-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.chip-list li {
		font-size: 0.9rem;
		color: var(--text);
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 0.25em 0.9em;
	}

	.cards {
		display: grid;
		gap: 1.5rem;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
	}

	.card {
		border: 1px solid var(--border);
		border-radius: 1rem;
		padding: 1.5rem;
		display: grid;
		gap: 0.75rem;
		background: var(--surface);
	}

	.card p {
		margin: 0;
	}

	@media (max-width: 720px) {
		main {
			padding: 3rem 1.25rem 5rem;
		}

		.section--muted {
			padding: 2.5rem 1.5rem;
		}
	}
</style>

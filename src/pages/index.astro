---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE, BASE } from '../consts';
import { projects } from '../data/projects';
import { skills } from '../data/skills';

const hero = {
	role: 'AI/ML Engineer · RL & LLM Systems',
	heading: `Hi, I'm ${SITE_TITLE}`,
	tagline:
		'I build AI systems that ship — RAG pipelines, agentic workflows, and reinforcement learning applied to real financial products.',
	ctaPrimary: { label: 'View Projects', href: '#projects' },
	ctaSecondary: { label: 'Download Résumé', href: 'https://drive.google.com/file/d/1ibbziBlGoAV0hxftyB9Qi9ZzIrojPoQj/view?usp=sharing' },
};

const highlights = [
	{ value: '5+', label: 'Years of Developing' },
	{ value: 'MSc', label: 'RL Research · NTHU 2024' },
];

const featuredProjects = projects.filter((project) => project.featured);

const contact = {
	email: 'sakkarink12@gmail.com',
	linkedin: 'https://www.linkedin.com/in/sakkarin-krarat-bb6958140',
	github: 'https://github.com/SakkarinKt',
	location: 'Taipei, Republic of China(Taiwan)',
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section id="hero" class="section hero">
				<div class="hero__intro">
					<p class="hero__role mono-label">{hero.role}</p>
					<h1>{hero.heading}</h1>
					<p class="hero__tagline">{hero.tagline}</p>
					<div class="hero__ctas">
						<a class="btn btn--primary" href={hero.ctaPrimary.href}>{hero.ctaPrimary.label}</a>
						<a
							class="btn btn--ghost"
							href={hero.ctaSecondary.href}
							target="_blank"
							rel="noopener noreferrer"
							>{hero.ctaSecondary.label}</a
						>
					</div>
				</div>
				<ul class="hero__highlights">
					{highlights.map((highlight) => (
						<li>
							<span class="highlight__value">{highlight.value}</span>
							<span class="highlight__label">{highlight.label}</span>
						</li>
					))}
				</ul>
			</section>

			<section id="projects" class="section">
				<header class="section__header">
					<h2>Projects</h2>
					<p>Current work — reinforcement learning, GPU-optimized inference, and systems built to be measured.</p>
				</header>
				<div class="card-grid">
					{featuredProjects.map((project) => (
						<ProjectCard project={project} />
					))}
				</div>
			</section>

			<section id="skills" class="section section--muted">
				<header class="section__header">
					<h2>Skills &amp; Tools</h2>
					<p>The stack I reach for, roughly in the order I reach for it.</p>
				</header>
				<div class="skill-rows">
					{skills.map((group) => (
						<div class="skill-row">
							<h3 class="mono-label">{group.category}</h3>
							<ul class="chip-list">
								{group.items.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</div>
					))}
				</div>
			</section>

			<section id="about" class="section">
				<div class="section__header">
					<h2>About</h2>
					<p>The spark notes version of what I do and how I like to work.</p>
				</div>
				<div class="about">
					<p>
						My path runs from actuarial sciences through a reinforcement-learning master's to the
						work I do now: RAG pipelines, agentic workflows, and RL applied to finance. The common
						thread is applied math turned into software you can measure.
					</p>
					<p>
						I also ship the unglamorous parts: transfer-agent and portfolio-management systems in C#
						for enterprise clients, a Nuxt app running on Google Cloud Run, and a reproducible CUDA
						benchmarking workflow on cloud GPUs.
					</p>
					<a class="about__link" href={`${BASE}about/`}>Read the full story →</a>
				</div>
			</section>

			<section id="contact" class="section section--muted">
				<header class="section__header">
					<h2>Let’s Build Something</h2>
					<p>
						Ready to collaborate or jam on an idea? Reach out directly or connect on your favorite platform.
					</p>
				</header>
				<ul class="contact-list">
					<li>
						<strong>Email:</strong>
						<a href={`mailto:${contact.email}`}>{contact.email}</a>
					</li>
					<li>
						<strong>Location:</strong>
						<span>{contact.location}</span>
					</li>
					<li>
						<strong>LinkedIn:</strong>
						<a href={contact.linkedin} target="_blank" rel="noopener noreferrer">Connect</a>
					</li>
					<li>
						<strong>GitHub:</strong>
						<a href={contact.github} target="_blank" rel="noopener noreferrer">Follow</a>
					</li>
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: auto;
		max-width: 960px;
		margin: 0 auto;
		padding: 4rem 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 5rem;
	}

	.section {
		display: grid;
		gap: 2rem;
	}

	.section--muted {
		background: var(--surface);
		padding: 3rem 2rem;
		border-radius: 1rem;
		border: 1px solid var(--border);
	}

	.section__header {
		display: grid;
		gap: 0.75rem;
	}

	.section__header p {
		color: var(--text-muted);
		margin: 0;
	}

	.hero {
		gap: 3rem;
	}

	.hero__tagline {
		max-width: 52ch;
		color: var(--text);
		font-size: 1.1rem;
	}

	.hero__ctas {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: 1.5rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		border-radius: 999px;
		font-weight: 600;
		text-decoration: none;
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}

	.btn:hover {
		transform: translateY(-2px);
	}

	.btn--primary {
		background: var(--accent);
		color: var(--bg);
	}

	.btn--primary:hover {
		color: var(--bg);
	}

	.btn--ghost {
		border: 1px solid var(--border);
		color: inherit;
	}

	.hero__highlights {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
		gap: 1.5rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.hero__highlights li {
		display: grid;
		gap: 0.25rem;
	}

	.highlight__value {
		font-size: 2rem;
		font-weight: 700;
		color: var(--text-strong);
	}

	.highlight__label {
		color: var(--text-muted);
		font-size: 0.95rem;
	}

	.card-grid {
		display: grid;
		gap: 1.5rem;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
	}

	.skill-rows {
		display: grid;
		gap: 1.75rem;
	}

	.skill-row {
		display: grid;
		gap: 0.75rem;
	}

	.skill-row h3 {
		margin: 0;
		font-weight: 400;
	}

	.chip-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.chip-list li {
		font-size: 0.9rem;
		color: var(--text);
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 0.25em 0.9em;
	}

	.about {
		display: grid;
		gap: 1.25rem;
		max-width: 68ch;
	}

	.about p {
		margin: 0;
	}

	.about__link {
		color: var(--accent);
		font-weight: 600;
		text-decoration: none;
	}

	.about__link:hover {
		color: var(--accent-hover);
	}

	.contact-list {
		list-style: none;
		display: grid;
		gap: 1rem;
		margin: 0;
		padding: 0;
	}

	.contact-list a {
		color: inherit;
		text-decoration: underline;
	}

	@media (max-width: 720px) {
		main {
			padding: 3rem 1.25rem;
		}

		.section--muted {
			padding: 2.5rem 1.5rem;
		}
	}
</style>
